  "description": "A backend server for LMS system with payment gateway",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "prestart": "npm run build",
